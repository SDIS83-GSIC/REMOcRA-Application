{
  "name": "remocra",
  "version": "0.0.0",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "biome:migrate": "biome migrate --write",
    "cleanParcelBuild": "rm -rf build/parceljs",
    "prebuild": "npm run cleanParcelBuild",
    "build": "parcel build --no-autoinstall --dist-dir build/parceljs --cache-dir build/cache/parcel src/index.html src/style.scss && npm run copy:cmaps && npm run copy:standard_fonts",
    "watch": "parcel watch --no-autoinstall --dist-dir build/parceljs --cache-dir build/cache/parcel src/index.html && npm run copy:cmaps && npm run copy:standard_fonts",
    "format:biome": "biome format --write",
    "format:assist": "biome check --formatter-enabled=false --linter-enabled=false --write",
    "format": "run-p format:*",
    "fix": "biome check --write",
    "lint:biome": "biome check",
    "lint-tsc": "tsc --noemit --pretty",
    "lint": "run-p lint:*",
    "bom": "npx @cyclonedx/cyclonedx-npm --omit dev --package-lock-only > npm-sbom.json",
    "copy:cmaps": "rm -rf public/cmaps && mkdir -p public/cmaps && cp -r node_modules/pdfjs-dist/cmaps/* public/cmaps/",
    "copy:standard_fonts": "rm -rf public/standard_fonts && mkdir -p public/standard_fonts && cp -r node_modules/pdfjs-dist/standard_fonts/* public/standard_fonts/"
  },
  "dependencies": {
    "@dnd-kit/accessibility": "^3.1.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@flaticon/flaticon-uicons": "^3.3.1",
    "@popperjs/core": "^2.11.8",
    "@types/react-csv": "^1.1.10",
    "bootstrap": "^5.3.8",
    "ci": "^2.3.0",
    "classnames": "^2.5.1",
    "cookie": "^1.1.1",
    "core-js": "^3.48.0",
    "date-fns": "^4.1.0",
    "formik": "^2.4.9",
    "lodash.debounce": "^4.0.8",
    "ol": "^10.7.0",
    "pdfjs-dist": "5.4.296",
    "proj4": "^2.20.2",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-async": "10.0.1",
    "react-bootstrap": "^2.10.10",
    "react-bootstrap-typeahead": "^6.4.1",
    "react-csv": "^2.2.2",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "react-pdf": "^10.3.0",
    "react-select": "^5.10.2",
    "recharts": "^2.15.4",
    "regenerator-runtime": "^0.14.1",
    "sass": "1.97.3",
    "use-debounce": "^10.1.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/preset-env": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@babel/runtime": "^7.28.6",
    "@biomejs/biome": "2.3.13",
    "@cyclonedx/cyclonedx-npm": "^3.1.0",
    "@parcel/transformer-sass": "^2.16.3",
    "@types/proj4": "^2.19.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.23",
    "babel-loader": "^9.2.1",
    "babel-plugin-inline-react-svg": "^2.0.2",
    "buffer": "^6.0.3",
    "mini-css-extract-plugin": "^2.9.4",
    "npm-run-all2": "^6.2.6",
    "parcel": "^2.16.3",
    "postcss": "^8.5.6",
    "postcss-import": "16.1.1",
    "postcss-modules": "6.0.1",
    "postcss-modules-values": "4.0.0",
    "postcss-preset-env": "10.4.0",
    "process": "^0.11.10",
    "typescript": "5.9.3",
    "webpack-cli": "^5.1.4"
  }
}
